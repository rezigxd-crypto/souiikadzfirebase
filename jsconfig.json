{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":        ["src/*"],
      "@components/*": ["src/components/*"],
      "@context/*":   ["src/context/*"],
      "@pages/*":     ["src/pages/*"],
      "@hooks/*":     ["src/hooks/*"],
      "@data/*":      ["src/data/*"],
      "@lib/*":       ["src/lib/*"],
      "@i18n/*":      ["src/i18n/*"],
      "@assets/*":    ["src/assets/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2020",
    "checkJs": false
  },
  "exclude": ["node_modules", "dist"]
}
